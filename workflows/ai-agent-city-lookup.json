      "webhookId": "1b962a34-6f2d-478d-8e2f-db6707e91da7"
    },
    {
      "parameters": {
        "promptType": "auto",
        "options": {
          "systemMessage": "You are a geography assistant. Use the Geomelon tool to look up cities, countries, regions, and distances. Prefer the Oneshot Autocomplete operation for quick free-text city name lookups, and the other City/Country/Region operations for structured queries by ID or coordinates."
        }
      },
